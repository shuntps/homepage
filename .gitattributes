# Normalize line endings: LF in the repository and on checkout
* text=auto eol=lf

# Text files
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.ico binary
*.ttf binary
*.woff binary
*.woff2 binary
