# Site

# The domain name displayed on the homepage (also used for metadata & Traefik routing)
SITE_DOMAIN=example.com

# Short description used in SEO meta tags, Open Graph, and JSON-LD
SITE_DESCRIPTION=Your site description here.

# Comma-separated list of SEO keywords
SITE_KEYWORDS=homelab,self-hosted,infrastructure

# Author name used in metadata
SITE_AUTHOR=yourname

# Locale tag, normalized by the app for HTML/browser APIs and Open Graph
SITE_LOCALE=en_CA

# Fixed expiry date for /.well-known/security.txt (RFC 9116, ISO 8601)
# Leave empty to auto-generate "now + 1 year" on each request
SECURITY_TXT_EXPIRES=

# Contact URI for /.well-known/security.txt (mailto: or https:)
# Leave empty to fall back to the site root URL
SECURITY_TXT_CONTACT=

# Comma-separated list of IPs/hosts allowed for HMR cross-origin in dev (dev only, ignored in production)
DEV_ALLOWED_ORIGINS=192.168.x.x

# Docker / Compose

# Docker Hub image tag to deploy (e.g. 1.2.3). Empty or unset = latest
HOMEPAGE_VERSION=latest

# Container name
HOMEPAGE_CONTAINER_NAME=homepage

# Port the Next.js server listens on inside the container
HOMEPAGE_WEB_PORT=3000

# Timezone
TZ=America/Toronto
